<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Policlinica.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="Policlinica.Views.AdminView"
        x:DataType="viewModels:AdminViewModel"
        Background="Black">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Red"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2a2a2a"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1a1a1a"/>
        </Style>
    </UserControl.Styles>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40" Spacing="20">
            <!-- Заголовок -->
            <TextBlock Text="Управление записями" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
            
            <!-- Поиск -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="10">
                    <TextBlock Text="Поиск записи:" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <TextBox Text="{Binding SearchText}" 
                             Watermark="Поиск по имени/фамилии (ищет при вводе)" 
                             Width="500"/>
                </StackPanel>
            </Border>
            
            <!-- Таблица записей -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="10">
                    <TextBlock Text="Список всех записей:" 
                               FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding RecordsList}" 
                                  SelectedItem="{Binding SelectedRecord}"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  Background="#333333">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding ClientName}" Header="Имя" Width="80"/>
                                <DataGridTextColumn Binding="{Binding ClientSurname}" Header="Фамилия" Width="80"/>
                                <DataGridTextColumn Binding="{Binding Title}" Header="Врач" Width="90"/>
                                <DataGridTextColumn Binding="{Binding Cabinet}" Header="Кабинет" Width="60"/>
                                <DataGridTextColumn Binding="{Binding HospitalName}" Header="Больница" Width="90"/>
                                <DataGridTextColumn Binding="{Binding AppointmentTime}" Header="Время" Width="60"/>
                                <DataGridTextColumn Binding="{Binding TotalAmount}" Header="Цена" Width="60"/>
                                <DataGridTextColumn Binding="{Binding ServiceName}" Header="Услуги" Width="150"/>
                                <DataGridTextColumn Binding="{Binding PhoneNumber}" Header="Телефон" Width="100"/>
                                <DataGridTextColumn Binding="{Binding RecordDate, StringFormat='yyyy-MM-dd'}" Header="Дата" Width="90"/>
                                <DataGridTextColumn Binding="{Binding Status}" Header="Статус" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Сообщение статуса -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="Yellow" FontSize="14" TextWrapping="Wrap" MinHeight="20"/>
           
            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,0">
                <Button Content="✏️ Редактировать" 
                        Background="DodgerBlue"
                        Command="{Binding EditRecordCommand}"
                        IsEnabled="{Binding SelectedRecord, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <Button Content="🗑️ Удалить" 
                        Background="Crimson"
                        Command="{Binding DeleteRecordCommand}"
                        IsEnabled="{Binding SelectedRecord, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <Button Content="➕ Добавить запись" 
                        Background="LimeGreen"
                        Command="{Binding GoServiceCommand}"/>
                <Button Content="👥 Управление пациентами" 
                        Background="MediumPurple"
                        Command="{Binding GoPatientManagementCommand}"/>
                <Button Content="🚪 Выход" 
                        Background="Red"
                        Command="{Binding ExitApplicationCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
