<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Policlinica.ViewModels"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="800"
        x:Class="Policlinica.Views.SugarCheckView"
        x:DataType="viewModels:SugarCheckViewModel"
        Background="Black">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Red"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40" Spacing="20">
            <TextBlock Text="Проверка нормы сахара в крови" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
            
            <!-- Вес -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="10">
                    <TextBlock Text="Вес (кг): *" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <TextBox Name="WeightInput" Watermark="Введите вес в килограммах" MaxLength="10"/>
                </StackPanel>
            </Border>
            
            <!-- Рост -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="10">
                    <TextBlock Text="Рост (см): *" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <TextBox Name="HeightInput" Watermark="Введите рост в сантиметрах" MaxLength="10"/>
                </StackPanel>
            </Border>
            
            <!-- Результат -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <TextBlock Text="{Binding Result}" 
                           FontSize="16" 
                           TextWrapping="Wrap" 
                           Foreground="LimeGreen"
                           FontWeight="Bold"
                           MinHeight="80"/>
            </Border>
            
            <!-- Статус -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="Yellow" FontSize="14" TextWrapping="Wrap" MinHeight="20"/>
            
            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                <Button Content="🧮 Рассчитать" 
                        Background="DodgerBlue"
                        Command="{Binding CalculateCommand}"/>
                <Button Content="↶ Назад" 
                        Background="Gray"
                        Command="{Binding BackCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
