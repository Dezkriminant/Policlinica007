<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Policlinica.ViewModels"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="800"
        x:Class="Policlinica.Views.BloodSugarInputView"
        x:DataType="viewModels:BloodSugarInputViewModel"
        Background="Black">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Red"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2a2a2a"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1a1a1a"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40" Spacing="20">
            
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Измерение уровня сахара в крови" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding PatientInfo}" FontSize="16" Foreground="LimeGreen" HorizontalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <!-- История измерений -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="10">
                    <TextBlock Text="История измерений:" 
                               FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding BloodSugarHistory}"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  Background="#333333">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding MeasurementDate, StringFormat='yyyy-MM-dd'}" Header="Дата" Width="120"/>
                                <DataGridTextColumn Binding="{Binding SugarLevel}" Header="Уровень (мг/дл)" Width="120"/>
                                <DataGridTemplateColumn Header="Удалить" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️ Удалить" 
                                                    Background="Crimson"
                                                    FontSize="12"
                                                    Padding="8,5"
                                                    Command="{Binding $parent[DataGrid].DataContext.DeleteRecordCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Добавление нового измерения -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="12">
                    <TextBlock Text="Добавить новое измерение:" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Уровень сахара (мг/дл): *" FontWeight="Bold" Foreground="White"/>
                        <TextBox Text="{Binding SugarLevel}" Watermark="Введите значение" MaxLength="10"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Дата (YYYY-MM-DD): *" FontWeight="Bold" Foreground="White"/>
                        <TextBox Text="{Binding MeasurementDate}" MaxLength="10"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="Yellow" FontSize="12" TextWrapping="Wrap" MinHeight="20"/>

                    <Button Content="💾 Сохранить измерение" 
                            Background="LimeGreen"
                            Command="{Binding AddBloodSugarCommand}"/>
                </StackPanel>
            </Border>

            <!-- Кнопка назад -->
            <Button Content="↶ Назад" 
                    Background="Gray"
                    Command="{Binding GoBackCommand}"
                    HorizontalAlignment="Center"
                    Width="150"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
