<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Policlinica.ViewModels"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="800"
        x:Class="Policlinica.Views.ServiceView"
        x:DataType="viewModels:ServiceViewModel"
        Background="Black">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Red"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#333333"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
        
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40" Spacing="20">
                
            <TextBlock Text="Выберите услугу и введите контактные данные" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
            
            <!-- Номер телефона пациента (read-only) -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="8">
                    <TextBlock Text="Номер телефона пациента:" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <TextBox Text="{Binding PatientPhone}" IsReadOnly="True" Background="DarkGray" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Услуги -->
            <Border BorderBrush="White" CornerRadius="8" BorderThickness="2" Padding="15" Background="Black">
                <StackPanel Spacing="10">
                    <TextBlock Text="Доступные услуги:" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <ListBox ItemsSource="{Binding Services}" MinHeight="280">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" BorderBrush="DarkGray" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Service.ServiceName}" Width="300" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Service.Price}" Width="120" FontSize="14" Foreground="LimeGreen" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Статус -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="Yellow" FontSize="14" TextWrapping="Wrap" MinHeight="20"/>
            
            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                <Button Content="✓ Продолжить" 
                        Background="LimeGreen"
                        Command="{Binding ContinueToDateTimeCommand}"/>
                <Button Content="↶ Назад" 
                        Background="Gray"
                        Command="{Binding GoBackCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
        
</UserControl>
