<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Policlinica.ViewModels"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="Policlinica.Views.DoctorSelectionView"
        x:DataType="viewModels:DoctorSelectionViewModel"
        Title="Выбор врача"
        WindowStartupLocation="CenterOwner"
        Width="700"
        Height="600"
        Background="White">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Red"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Styles>

    <Border BorderBrush="DodgerBlue" CornerRadius="8" BorderThickness="2" Padding="20" Background="White">
        <StackPanel Spacing="15">
            <TextBlock Text="Выбор врача" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
            
            <!-- Поиск врача -->
            <StackPanel Spacing="8">
                <TextBlock Text="Поиск врача:" FontWeight="Bold" Foreground="Black"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBox Watermark="Введите для поиска..." Text="{Binding SearchText}" Height="40" Width="400"/>
                    <Button Content="🔍 Поиск" 
                            Background="DodgerBlue"
                            Click="SearchButton_Click"
                            Width="120"/>
                </StackPanel>
            </StackPanel>

            <!-- Список врачей -->
            <StackPanel Spacing="8">
                <TextBlock Text="Список врачей:" FontWeight="Bold" Foreground="Black"/>
                <ListBox ItemsSource="{Binding Doctors}" 
                         SelectedItem="{Binding SelectedDoctor}"
                         Height="280"
                         BorderBrush="Black"
                         BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" BorderBrush="LightGray" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="*,*">
                                    <StackPanel Grid.Column="0" Spacing="5">
                                        <TextBlock Text="{Binding Title, StringFormat='Специальность: {0}'}" 
                                                   FontSize="14" 
                                                   FontWeight="Bold"
                                                   Foreground="Black"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="5" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Cabinet, StringFormat='Кабинет: {0}'}" 
                                                   FontSize="14" 
                                                   FontWeight="Bold"
                                                   Foreground="DodgerBlue"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Информация о выбранном враче -->
            <Border BorderBrush="LimeGreen" CornerRadius="5" BorderThickness="2" Padding="10" Background="WhiteSmoke">
                <StackPanel Spacing="5">
                    <TextBlock Text="Выбранный врач:" FontWeight="Bold" Foreground="Black" FontSize="12"/>
                    <TextBlock Text="{Binding SelectedDoctor.Title, StringFormat='Специальность: {0}'}" 
                               Foreground="Black" FontSize="12"/>
                    <TextBlock Text="{Binding SelectedDoctor.Cabinet, StringFormat='Кабинет: {0}'}" 
                               Foreground="DodgerBlue" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Кнопки действия -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,10,0,0">
                <Button Content="✓ Выбрать врача" 
                        Background="LimeGreen"
                        Click="SelectButton_Click"
                        IsEnabled="{Binding SelectedDoctor, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <Button Content="↶ Назад" 
                        Background="Gray"
                        Click="BackButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
